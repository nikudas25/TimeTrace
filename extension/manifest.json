{
  "manifest_version": 3,
  "name": "TimeTrace",
  "version": "1.0",
  "permissions": ["tabs", "storage", "activeTab", "idle"],
  "host_permissions": ["http://127.0.0.1:8000/*", "https://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },

  "action": {
  "default_popup": "popup.html"
  } 
}